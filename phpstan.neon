parameters:
    level: 8

    paths:
        - src/
        - lib/

    excludePaths:
        - */vendor/*
        - */tests/*
        - */assets/*
        - admin/views/*

    # ─── WordPress 全局变量 ───
    universalObjectCratesClasses:
        - WP_Query
        - WP_Post
        - WP_Error
        - WP_HTTP
        - WP_REST_Request
        - WP_REST_Response
        - WP_REST_Server
        - WP_Widget

    # ─── 忽略 WordPress 类未找到 (无存根) ───
    ignoreErrors:
        - '#Constant LINKED3_(DIR|URL|VERSION|BASENAME|FILE|PLUGIN_FILE) not found.#'
        - '#Function .* not found.#'
        - '#Instantiated class .* not found.#'
        - '#Caught class .* not found.#'
        - '#Call to static method .* on an unknown class.*#'
        - '#Call to method .* on an unknown class.*#'
        - '#Throwing object of an unknown class.*#'

    # ─── 允许混合数组 (WordPress 惯例) ───
    checkAlwaysTrueInstanceof: false

    # ─── 报告风格 ───
    reportUnmatchedIgnoredErrors: false
